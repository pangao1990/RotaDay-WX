.settings-body {
  padding-top: 26rpx;
}

.settings-group-title {
  display: block;
  margin: 30rpx 0 13rpx;
  color: var(--muted);
  font-size: 24rpx;
  font-weight: 600;
}

.settings-group {
  overflow: hidden;
}

.settings-row {
  width: 100%;
  min-height: 116rpx;
  padding: 18rpx 22rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  border-top: 2rpx solid var(--border);
  text-align: left;
}

.settings-row:first-child {
  border-top: 0;
}

.settings-icon {
  width: 68rpx;
  height: 68rpx;
  flex: none;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--brand);
  background: var(--brand-soft);
  font-size: 23rpx;
  font-weight: 800;
}

.settings-copy {
  min-width: 0;
  flex: 1;
  margin-left: 18rpx;
}

.settings-copy > text:first-child {
  display: block;
  color: var(--text);
  font-size: 27rpx;
  font-weight: 700;
}

.settings-copy .small {
  display: block;
  margin-top: 7rpx;
  color: var(--muted);
  font-size: 21rpx;
}

.settings-value {
  max-width: 150rpx;
  margin-left: 12rpx;
  color: var(--muted);
  font-size: 22rpx;
  text-align: right;
}

.chevron {
  margin-left: 12rpx;
  color: var(--brand);
  font-size: 38rpx;
}

.settings-modal {
  max-width: 780rpx;
}

.intro-card {
  padding: 24rpx;
  border-radius: 18rpx;
  color: var(--text);
  background: var(--subtle);
  font-size: 26rpx;
  line-height: 1.55;
}

.intro-card > text {
  display: block;
}

.intro-card .small {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 22rpx;
  line-height: 1.55;
}

.mode-card {
  width: 100%;
  min-height: 130rpx;
  margin-top: 18rpx;
  padding: 20rpx;
  border: 2rpx solid var(--border);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  text-align: left;
}

.mode-card.selected {
  border-color: var(--brand);
  background: var(--brand-soft);
}

.mode-mark {
  width: 76rpx;
  height: 76rpx;
  flex: none;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  background: var(--brand);
  font-size: 28rpx;
  font-weight: 800;
}

.mode-mark.team {
  background: var(--accent);
}

.mode-card > view {
  min-width: 0;
  flex: 1;
  margin-left: 20rpx;
}

.mode-name {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
}

.mode-card .small {
  display: block;
  margin-top: 7rpx;
  color: var(--muted);
  font-size: 22rpx;
}

.mode-check {
  margin-left: 14rpx;
  color: var(--brand);
  font-size: 36rpx;
}

.theme-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.theme-card {
  min-width: 0;
  min-height: 238rpx;
  padding: 20rpx;
  border: 3rpx solid;
  border-radius: 20rpx;
  box-sizing: border-box;
  text-align: left;
}

.theme-card.selected {
  border-width: 5rpx;
}

.theme-swatches {
  display: flex;
  align-items: center;
}

.theme-swatches > view:first-child {
  width: 66rpx;
  height: 66rpx;
  border-radius: 17rpx;
}

.theme-swatches > view:last-child {
  margin-left: 13rpx;
  display: flex;
  flex-direction: column;
  gap: 7rpx;
}

.theme-swatches > view:last-child text {
  width: 48rpx;
  height: 24rpx;
  border: 2rpx solid transparent;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.theme-card-title {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.theme-card-title > text:first-child {
  font-size: 29rpx;
  font-weight: 800;
}

.theme-state {
  font-size: 19rpx;
  text-align: right;
}

.theme-description {
  display: -webkit-box;
  margin-top: 10rpx;
  overflow: hidden;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  font-size: 21rpx;
  line-height: 1.5;
}

.custom-theme-editor {
  margin-top: 28rpx;
  padding-top: 4rpx;
  border-top: 2rpx solid var(--border);
}

.mini-color-grid,
.shift-color-grid {
  margin-top: 14rpx;
  display: grid;
  gap: 16rpx 12rpx;
}

.mini-color-grid {
  grid-template-columns: repeat(5, minmax(0, 1fr));
}

.shift-color-grid {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.mini-color-grid button {
  width: 80rpx;
  height: 80rpx;
  justify-self: center;
  border: 2rpx solid transparent;
  border-radius: 14rpx;
}

.full-button {
  width: 100%;
  margin-top: 24rpx;
}

.segmented {
  padding: 7rpx;
  display: flex;
  border-radius: 18rpx;
  background: var(--subtle);
}

.segmented button {
  flex: 1;
  min-height: 78rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  color: var(--muted);
  font-size: 25rpx;
  font-weight: 600;
  line-height: 1.2;
  text-align: center;
}

.segmented button.active {
  color: var(--on-brand);
  background: var(--brand);
}

.first-label {
  margin-top: 0;
}

.setting-control-row {
  min-height: 108rpx;
  padding: 20rpx 0;
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid var(--border);
}

.setting-control-row > view {
  min-width: 0;
  flex: 1;
  margin-right: 20rpx;
}

.setting-control-row > view > text:first-child {
  display: block;
  font-size: 27rpx;
  font-weight: 700;
}

.setting-control-row .small {
  display: block;
  margin-top: 7rpx;
  color: var(--muted);
  font-size: 21rpx;
  line-height: 1.45;
}

.form-hint {
  display: block;
  margin-top: 10rpx;
  color: var(--faint);
  font-size: 21rpx;
  line-height: 1.5;
}

.no-border {
  border-bottom: 0;
}

.option-grid {
  display: grid;
  gap: 14rpx;
}

.two-columns {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.three-columns {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.option-card {
  min-height: 86rpx;
  padding: 0 10rpx;
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  color: var(--text);
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.25;
  text-align: center;
}

.option-card.selected {
  color: var(--brand);
  border-color: var(--brand);
  background: var(--brand-soft);
}

.shift-tabs {
  margin-bottom: 20rpx;
}

.cycle-card {
  position: relative;
  width: 100%;
  min-height: 142rpx;
  margin-top: 14rpx;
  padding: 20rpx 58rpx 20rpx 20rpx;
  border: 2rpx solid var(--border);
  border-radius: 18rpx;
  box-sizing: border-box;
  text-align: left;
}

.cycle-card.selected {
  border-color: var(--brand);
  background: var(--brand-soft);
}

.cycle-copy > text:first-child {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
}

.cycle-copy .small {
  display: block;
  margin-top: 7rpx;
  color: var(--muted);
  font-size: 21rpx;
}

.cycle-preview {
  margin-top: 14rpx;
  display: flex;
  gap: 8rpx;
}

.cycle-preview text {
  width: 42rpx;
  height: 42rpx;
  border-radius: 11rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 700;
}

.cycle-check {
  position: absolute;
  top: 50%;
  right: 22rpx;
  color: var(--brand);
  font-size: 34rpx;
  transform: translateY(-50%);
}

.add-shift-button {
  margin-top: 0;
  margin-bottom: 16rpx;
}

.shift-list {
  overflow: hidden;
  border: 2rpx solid var(--border);
  border-radius: 18rpx;
}

.shift-row {
  width: 100%;
  min-height: 108rpx;
  padding: 16rpx 18rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  border-top: 2rpx solid var(--border);
  text-align: left;
}

.shift-row:first-child {
  border-top: 0;
}

.shift-dot {
  width: 24rpx;
  height: 24rpx;
  flex: none;
  border-radius: 50%;
}

.shift-row > view {
  min-width: 0;
  flex: 1;
  margin-left: 16rpx;
}

.shift-row > view > text:first-child {
  display: block;
  font-size: 27rpx;
  font-weight: 700;
}

.shift-row .small {
  display: block;
  margin-top: 6rpx;
  color: var(--muted);
  font-size: 21rpx;
}

.built-in-tag {
  padding: 7rpx 10rpx;
  border-radius: 9rpx;
  color: var(--brand);
  background: var(--brand-soft);
  font-size: 18rpx;
}

.backup-action {
  width: 100%;
  min-height: 118rpx;
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border: 2rpx solid var(--border);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  text-align: left;
}

.backup-icon {
  width: 70rpx;
  height: 70rpx;
  flex: none;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--brand);
  background: var(--brand-soft);
  font-size: 34rpx;
}

.backup-action > view {
  min-width: 0;
  flex: 1;
  margin-left: 18rpx;
}

.backup-action > view > text:first-child {
  display: block;
  font-size: 27rpx;
  font-weight: 700;
}

.backup-action .small {
  display: block;
  margin-top: 7rpx;
  color: var(--muted);
  font-size: 21rpx;
}

.danger-backup {
  color: #B04E43;
  border-color: #E7BDB7;
}

.about-hero {
  padding: 10rpx 0 26rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.about-hero image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 34rpx;
}

.about-name {
  margin-top: 18rpx;
  font-size: 40rpx;
  font-weight: 800;
}

.about-slogan {
  margin-top: 7rpx;
  color: var(--muted);
  font-size: 25rpx;
}

.about-version {
  margin-top: 8rpx;
  color: var(--faint);
  font-size: 21rpx;
}

.about-description {
  padding: 26rpx 8rpx 4rpx;
}

.about-description text {
  display: block;
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.75;
  text-align: justify;
}

.about-description text + text {
  margin-top: 18rpx;
}

.about-actions {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}

.about-actions button {
  min-width: 0;
  flex: 1;
}

.nested-mask {
  z-index: 1200;
}

.shift-color-choice {
  width: 80rpx;
  height: 80rpx;
  justify-self: center;
  border: 5rpx solid transparent;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  color: #FFFFFF;
  font-size: 28rpx;
}

.shift-color-choice.selected {
  border-color: var(--text);
}

.color-more {
  margin-top: 16rpx;
}

.delete-shift {
  max-width: 154rpx;
}
