.home-body {
  padding-top: 22rpx;
}

.greeting-panel {
  width: 100%;
  min-height: 122rpx;
  margin-bottom: 26rpx;
  padding: 20rpx 22rpx;
  display: flex;
  align-items: stretch;
  text-align: left;
  border: 2rpx solid var(--border);
  border-radius: 20rpx;
  background: var(--brand-soft);
  box-shadow: 0 8rpx 28rpx var(--shadow);
  box-sizing: border-box;
}

.greeting-stripe {
  width: 9rpx;
  flex: none;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  border-radius: 8rpx;
}

.greeting-stripe > view { flex: 1; }
.greeting-stripe > view:nth-child(1) { background: var(--warm); }
.greeting-stripe > view:nth-child(2) { background: var(--accent); }
.greeting-stripe > view:nth-child(3) { background: var(--brand); }

.greeting-copy {
  min-width: 0;
  flex: 1;
  margin-left: 18rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.greeting-date {
  color: var(--muted);
  font-size: 21rpx;
  line-height: 1.2;
}

.greeting-text {
  margin-top: 7rpx;
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  color: var(--text);
  font-size: 27rpx;
  line-height: 1.42;
}

.greeting-open {
  flex: none;
  align-self: center;
  margin-left: 16rpx;
  padding: 10rpx 15rpx;
  border-radius: 999rpx;
  color: var(--brand);
  background: var(--surface);
  font-size: 21rpx;
  font-weight: 700;
}

.today-card {
  min-height: 242rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.today-main {
  min-width: 0;
  flex: 1;
}

.eyebrow {
  display: block;
  color: var(--muted);
  font-size: 25rpx;
  line-height: 1.35;
}

.shift-name-row {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
}

.shift-name-row > view {
  width: 11rpx;
  height: 70rpx;
  margin-right: 24rpx;
  border-radius: 8rpx;
}

.shift-name-row text {
  font-size: 55rpx;
  font-weight: 800;
  line-height: 1.2;
}

.shift-time {
  display: block;
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 29rpx;
}

.today-status {
  display: block;
  margin-top: 13rpx;
  color: var(--brand);
  font-size: 27rpx;
  line-height: 1.45;
}

.today-action {
  flex: none;
  width: 112rpx;
  min-height: 150rpx;
  margin-left: 20rpx;
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 13rpx;
  color: var(--brand);
  background: var(--brand-soft);
  font-size: 24rpx;
  font-weight: 700;
}

.today-action-icon {
  position: relative;
  width: 58rpx;
  height: 58rpx;
  border-radius: 17rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--brand);
  background: var(--surface);
  box-sizing: border-box;
}

.edit-pencil {
  position: absolute;
  left: 50%;
  top: 45%;
  width: 29rpx;
  height: 8rpx;
  border-radius: 5rpx 2rpx 2rpx 5rpx;
  background: var(--brand);
  transform: translate(-50%, -50%) rotate(-42deg);
}

.edit-icon::before {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 11rpx;
  width: 25rpx;
  height: 19rpx;
  border-left: 3rpx solid var(--brand);
  border-bottom: 3rpx solid var(--brand);
  border-radius: 0 0 0 5rpx;
  box-sizing: border-box;
  opacity: .32;
  transform: translateX(-50%);
}

.edit-pencil::before {
  content: '';
  position: absolute;
  top: 0;
  right: -8rpx;
  width: 0;
  height: 0;
  border-top: 4rpx solid transparent;
  border-bottom: 4rpx solid transparent;
  border-left: 8rpx solid var(--brand);
}

.edit-pencil::after {
  content: '';
  position: absolute;
  top: 0;
  left: -6rpx;
  width: 6rpx;
  height: 8rpx;
  border-radius: 4rpx 0 0 4rpx;
  background: var(--brand);
  opacity: .45;
}

.add-icon::before,
.add-icon::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  border-radius: 3rpx;
  background: var(--brand);
  transform: translate(-50%, -50%);
}

.add-icon::before {
  width: 28rpx;
  height: 6rpx;
}

.add-icon::after {
  width: 6rpx;
  height: 28rpx;
}

.team-count-row {
  display: flex;
  align-items: baseline;
  margin-top: 10rpx;
}

.team-count {
  font-size: 62rpx;
  line-height: 1;
  font-weight: 800;
}

.team-count-unit {
  margin-left: 14rpx;
  color: var(--muted);
  font-size: 28rpx;
}

.team-preview {
  color: var(--muted);
  font-size: 24rpx;
}

.calendar-card {
  padding: 28rpx 22rpx 20rpx;
  margin-bottom: 30rpx;
}

.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8rpx 18rpx 18rpx;
}

.month-picker {
  min-width: 0;
}

.month-picker-content {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.month-title {
  color: var(--text);
  font-size: 36rpx;
  font-weight: 800;
}

.month-picker-hint {
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  color: var(--brand);
  background: var(--brand-soft);
  font-size: 19rpx;
  font-weight: 700;
}

.calendar-tools {
  display: flex;
  gap: 10rpx;
}

.calendar-tool {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text);
  background: var(--subtle);
  font-size: 46rpx;
  font-weight: 400;
}

.today-tool {
  color: var(--brand);
  font-size: 25rpx;
  font-weight: 700;
}

@media (max-width: 340px) {
  .greeting-open {
    display: none;
  }

  .today-card {
    padding: 26rpx;
  }

  .today-action {
    width: 102rpx;
    margin-left: 14rpx;
  }

  .month-picker-hint {
    display: none;
  }
}

.week-row,
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
}

.week-row text {
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--muted);
  font-size: 23rpx;
}

.calendar-day {
  position: relative;
  min-width: 0;
  height: 105rpx;
  margin: 3rpx;
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.calendar-day.outside {
  opacity: .48;
}

.calendar-day.selected {
  color: var(--brand);
  background: var(--brand-soft);
  border-color: var(--brand);
}

.calendar-day.today:not(.selected)::after {
  content: '';
  position: absolute;
  top: 10rpx;
  right: 12rpx;
  width: 7rpx;
  height: 7rpx;
  border-radius: 50%;
  background: var(--brand);
}

.day-number {
  font-size: 28rpx;
  line-height: 1;
  font-weight: 700;
}

.day-shift-row {
  height: 32rpx;
  margin-top: 9rpx;
  display: flex;
  align-items: center;
}

.day-shift {
  font-size: 24rpx;
  line-height: 1;
}

.override-dot {
  margin-right: 3rpx;
  color: var(--brand);
  font-size: 27rpx;
}

.day-team-count {
  min-height: 30rpx;
  margin-top: 9rpx;
  color: var(--brand);
  font-size: 22rpx;
}

.calendar-hint {
  display: block;
  padding: 14rpx 8rpx 0;
  color: var(--faint);
  font-size: 21rpx;
  text-align: center;
}

.selected-card {
  padding: 28rpx;
  margin-bottom: 28rpx;
}

.selected-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.selected-date {
  display: block;
  margin-top: 6rpx;
  font-size: 31rpx;
  font-weight: 700;
}

.override-tag {
  flex: none;
  padding: 9rpx 14rpx;
  border-radius: 10rpx;
  color: var(--brand);
  background: var(--brand-soft);
  font-size: 21rpx;
}

.selected-shift {
  margin-top: 26rpx;
  display: flex;
  align-items: center;
}

.selected-shift-dot {
  width: 22rpx;
  height: 22rpx;
  flex: none;
  border-radius: 50%;
}

.selected-shift-copy {
  min-width: 0;
  flex: 1;
  margin-left: 18rpx;
}

.selected-shift-copy text {
  display: block;
  font-size: 31rpx;
  font-weight: 700;
}

.selected-shift-copy .small {
  display: block;
  margin-top: 6rpx;
  color: var(--muted);
  font-size: 23rpx;
}

.selected-edit {
  width: 112rpx;
  min-height: 74rpx;
}

.compact-action {
  min-height: 72rpx;
  padding: 0 18rpx;
}

.team-preview-list {
  margin-top: 24rpx;
}

.team-preview-member,
.manager-member-row {
  width: 100%;
  min-height: 108rpx;
  padding: 14rpx 16rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  border-top: 2rpx solid var(--border);
  text-align: left;
}

.team-preview-member:first-child,
.manager-member-row:first-child {
  border-top: 0;
}

.member-avatar {
  width: 70rpx;
  height: 70rpx;
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 700;
}

.member-copy {
  min-width: 0;
  flex: 1;
  margin-left: 18rpx;
}

.member-copy text,
.member-shift text {
  display: block;
  font-size: 27rpx;
  font-weight: 700;
}

.member-copy .small,
.member-shift .small {
  display: block;
  margin-top: 6rpx;
  color: var(--muted);
  font-size: 21rpx;
}

.member-shift {
  flex: none;
  margin-left: 16rpx;
  text-align: right;
}

.compact-empty {
  padding: 36rpx 20rpx 12rpx;
}

.rest-strip {
  min-height: 122rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.rest-copy {
  display: block;
  margin-top: 7rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.rest-action {
  min-width: 104rpx;
  min-height: 104rpx;
  margin: -15rpx -18rpx -15rpx 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  color: var(--brand);
  font-size: 25rpx;
  font-weight: 700;
}

.picker-intro {
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.picker-intro text {
  min-width: 0;
  flex: 1;
  color: var(--muted);
  font-size: 25rpx;
  line-height: 1.5;
}

.picker-intro button {
  flex: none;
  min-height: 68rpx;
  padding: 0 18rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  color: var(--brand);
  background: var(--brand-soft);
  font-size: 23rpx;
}

.shift-picker-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.shift-option {
  min-width: 0;
  min-height: 116rpx;
  padding: 18rpx;
  border: 2rpx solid var(--border);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  text-align: left;
  box-sizing: border-box;
}

.shift-option.selected {
  border-color: var(--brand);
  background: var(--brand-soft);
}

.shift-option > view:first-child {
  width: 24rpx;
  height: 24rpx;
  flex: none;
  border-radius: 50%;
}

.shift-option > view {
  min-width: 0;
  flex: 1;
  margin-left: 16rpx;
}

.shift-option text {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
}

.shift-option .small {
  display: block;
  margin-top: 6rpx;
  color: var(--muted);
  font-size: 22rpx;
}

.shift-option .checkmark {
  color: var(--brand);
  font-size: 30rpx;
}

button[disabled] {
  opacity: .45;
}

.segmented {
  padding: 7rpx;
  display: flex;
  border-radius: 18rpx;
  background: var(--subtle);
}

.segmented button {
  flex: 1;
  min-height: 78rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  color: var(--muted);
  font-size: 25rpx;
  font-weight: 600;
  line-height: 1.2;
  text-align: center;
}

.segmented button.active {
  color: var(--on-brand);
  background: var(--brand);
}

.team-tabs {
  margin-bottom: 24rpx;
}

.manager-main-button {
  width: 100%;
  margin-bottom: 16rpx;
}

.manager-list {
  overflow: hidden;
  border: 2rpx solid var(--border);
  border-radius: 18rpx;
}

.row-chevron {
  margin-left: 10rpx;
  color: var(--brand);
  font-size: 38rpx;
}

.clipboard-note {
  margin-bottom: 14rpx;
  color: var(--muted);
  font-size: 23rpx;
}

.manager-action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.danger-outline {
  color: #B04E43;
  border-color: #E7BDB7;
}

.manager-action-grid .danger-outline {
  grid-column: 1 / -1;
}

.member-select-area {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  text-align: left;
}

.select-label {
  color: var(--brand);
  font-size: 23rpx;
}

.member-edit-button {
  flex: none;
  width: 80rpx;
  height: 80rpx;
  margin-left: 12rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  color: var(--brand);
  background: var(--brand-soft);
  line-height: 1;
}

.member-edit-icon {
  position: relative;
  width: 54rpx;
  height: 54rpx;
  border-radius: 13rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  background: var(--surface);
}

.member-profile-links {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.member-profile-links button {
  min-height: 68rpx;
  padding: 0 18rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  color: var(--text);
  background: var(--subtle);
  font-size: 23rpx;
}

.member-profile-links > button > view {
  width: 16rpx;
  height: 16rpx;
  margin-right: 10rpx;
  border-radius: 50%;
}

.nested-mask {
  z-index: 1200;
}

.full-button {
  width: 100%;
  margin-top: 28rpx;
}

.color-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 16rpx 12rpx;
}

.color-choice {
  width: 80rpx;
  height: 80rpx;
  justify-self: center;
  border: 5rpx solid transparent;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  color: #FFFFFF;
  font-size: 30rpx;
}

.color-choice.selected {
  border-color: var(--text);
}

.color-more {
  margin-top: 16rpx;
}

.delete-member {
  max-width: 154rpx;
}

.moment-mask {
  z-index: 1400;
}

.moment-card {
  max-width: 720rpx;
}

.moment-poster {
  position: relative;
  background: var(--surface);
}

.moment-image {
  width: 100%;
  height: 400rpx;
  display: block;
}

.moment-close {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #26312D;
  background: rgba(255,255,255,.92);
  font-size: 45rpx;
}

.moment-copy-area {
  padding: 30rpx 32rpx 26rpx;
}

.moment-kicker {
  display: block;
  color: var(--brand);
  font-size: 24rpx;
  font-weight: 600;
}

.moment-title {
  display: block;
  margin-top: 12rpx;
  color: var(--text);
  font-size: 42rpx;
  line-height: 1.3;
  font-weight: 800;
}

.moment-copy {
  display: block;
  margin-top: 16rpx;
  color: var(--muted);
  font-size: 27rpx;
  line-height: 1.7;
}

.moment-brand {
  margin-top: 26rpx;
  display: flex;
  align-items: center;
}

.moment-brand text {
  color: var(--brand);
  font-size: 23rpx;
  font-weight: 700;
}

.moment-brand .small {
  margin-left: 14rpx;
  color: var(--faint);
  font-size: 19rpx;
}

.moment-actions {
  padding: 12rpx 32rpx 0;
  display: flex;
  align-items: center;
}

.moment-icon-button {
  width: 76rpx;
  height: 76rpx;
  margin-right: 12rpx;
  border: 2rpx solid var(--border);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  color: var(--brand);
  background: var(--brand-soft);
  line-height: 1;
}

.moment-action-icon {
  position: relative;
  width: 38rpx;
  height: 38rpx;
  color: var(--brand);
}

.download-icon::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 1rpx;
  width: 5rpx;
  height: 21rpx;
  border-radius: 4rpx;
  background: currentColor;
  transform: translateX(-50%);
}

.download-icon::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 10rpx;
  width: 14rpx;
  height: 14rpx;
  border-right: 5rpx solid currentColor;
  border-bottom: 5rpx solid currentColor;
  border-radius: 2rpx;
  box-sizing: border-box;
  transform: translateX(-50%) rotate(45deg);
}

.download-icon > view,
.share-icon > view {
  position: absolute;
  left: 4rpx;
  bottom: 1rpx;
  width: 30rpx;
  height: 12rpx;
  border: 4rpx solid currentColor;
  border-top: 0;
  border-radius: 0 0 6rpx 6rpx;
  box-sizing: border-box;
}

.share-icon::before {
  content: '';
  position: absolute;
  left: 50%;
  top: 3rpx;
  width: 5rpx;
  height: 24rpx;
  border-radius: 4rpx;
  background: currentColor;
  transform: translateX(-50%);
}

.share-icon::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 2rpx;
  width: 14rpx;
  height: 14rpx;
  border-left: 5rpx solid currentColor;
  border-top: 5rpx solid currentColor;
  border-radius: 2rpx;
  box-sizing: border-box;
  transform: translateX(-50%) rotate(45deg);
}

.moment-actions > text {
  min-width: 0;
  flex: 1;
  color: var(--muted);
  font-size: 21rpx;
  text-align: right;
}

.moment-bottom-buttons {
  padding: 0 32rpx 30rpx;
}

.poster-canvas {
  position: fixed;
  left: 0;
  top: 0;
  width: 2px;
  height: 3px;
  opacity: 0;
  pointer-events: none;
  z-index: -1;
}

@media (min-width: 700px) {
  .page-body {
    max-width: 1040rpx;
  }
}
